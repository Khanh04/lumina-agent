# LLM planner (pydantic-ai model id). Swap provider by changing this + the matching key.
MODEL_NAME=google:gemini-flash-lite-latest
# Key for the chosen provider. For Gemini (google), pydantic-ai reads GOOGLE_API_KEY.
GOOGLE_API_KEY=
# For OpenAI (MODEL_NAME=openai:gpt-4o-mini) set OPENAI_API_KEY instead.
# OPENAI_API_KEY=

REDIS_URL=redis://localhost:6379/0

# Optional observability. Omit to disable (logfire uses "if-token-present").
LOGFIRE_TOKEN=
